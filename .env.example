# ============================================================
# 615 Project — Environment Variables
# คัดลอกไฟล์นี้ไปเป็น .env แล้วแก้ไขค่าตามต้องการ
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=615-project

# --- FastAPI Database URL (Docker internal) ---
# hostname = db (ชื่อ service ใน compose.yaml)
DATABASE_URL=postgresql+asyncpg://postgres:change_this_password@db:5432/615-project

# --- FastAPI root_path ---
# Docker/Nginx: "/api" , Local dev: ไม่ต้องตั้ง
API_ROOT_PATH=/api

# --- Next.js ---
# URL สำหรับเรียก API จาก browser (ผ่าน Nginx)
NEXT_PUBLIC_API_URL=http://localhost/api